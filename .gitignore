node_modules/
.env
.env.local
.env.*.local

# Ignore EVERYTHING under output/ by default...
output/*
output/**/*

# ...then allow ONLY the specific state-of-truth files we need on GitHub:
!output/leads/
output/leads/*
!output/leads/dental-v5-modern.json
!output/leads/dental-v4-qualified.json
!output/leads/dental-v5-outdated.json
!output/leads/lawyer-modern.json

!output/dental-campaign/
output/dental-campaign/*
!output/dental-campaign/send-state.json

!output/v5-campaign/
output/v5-campaign/*
!output/v5-campaign/send-state-v5.json
!output/v5-campaign/city-progress.json
!output/v5-campaign/osm-region-progress.json
!output/v5-campaign/send-state-v5-outdated.json
!output/v5-campaign/osm-region-progress-outdated.json
!output/v5-campaign/send-state-lawyer.json
!output/v5-campaign/osm-region-progress-lawyer.json

!output/outreach-state.json

!output/static/
output/static/*
!output/static/smartflowdev-dental-proposal.pdf
!output/static/smartflowdev-dental-proposal-en.pdf
!output/static/smartflowdev-dental-proposal-hu.pdf
!output/static/smartflowdev-dental-proposal-redesign-en.pdf

# Logs + tooling
*.log
npm-debug.log*
.DS_Store
Thumbs.db
.vscode/
.idea/
*.tsbuildinfo

